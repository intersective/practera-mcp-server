{
  "name": "practera-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Practera GraphQL API with OAuth 2.1 support",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "practera-ops": "./dist/cli/ops/index.js",
    "practera-dev": "./dist/cli/dev/index.js"
  },
  "scripts": {
    "start": "node dist/server.js",
    "start:stdio": "node dist/stdio.js",
    "ops": "node dist/cli/ops/index.js",
    "dev:ops": "node --loader ts-node/esm src/cli/ops/index.ts",
    "dev:cli": "node --loader ts-node/esm src/cli/dev/index.ts",
    "dev": "NODE_OPTIONS=\"--loader ts-node/esm\" node src/server.ts",
    "dev:stdio": "node --loader ts-node/esm src/stdio.ts",
    "build": "tsc && cp -r src/data dist/",
    "typecheck": "tsc --noEmit",
    "test": "echo \"Error: no test specified\" && exit 1",
    "deploy": "serverless deploy"
  },
  "keywords": [
    "mcp",
    "practera",
    "graphql",
    "ai",
    "llm",
    "oauth"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.9.0",
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.18.2",
    "graphql-request": "^6.1.0",
    "jose": "^5.9.6",
    "marked": "^18.0.6",
    "serverless-http": "^3.2.0",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.17",
    "@types/marked": "^5.0.2",
    "@types/node": "^18.17.0",
    "@types/uuid": "^10.0.0",
    "nodemon": "^3.0.3",
    "serverless": "^4.36.1",
    "serverless-offline": "^14.7.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
